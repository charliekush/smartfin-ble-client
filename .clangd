CompileFlags:
  CompilationDatabase: build
  Compiler: /usr/bin/clang++
  Add:
    - -std=c++20
    - -isysroot
    - /Library/Developer/CommandLineTools/SDKs/MacOSX.sdk
    - -Ismartfin-ble-client/src
    - -Ismartfin-ble-client/external/SimpleBLE/simpleble/include
    - -Ismartfin-ble-client/build/external/SimpleBLE/simpleble/export

If:
  PathMatch: .*simpleble_adapter\.(hpp|cpp)$
CompileFlags:
  Add:
    - -DSMARTFIN_ENABLE_SIMPLEBLE=1

Diagnostics:
  UnusedIncludes: Strict
